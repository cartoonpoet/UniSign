# App
NODE_ENV=development
PORT=4000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003

# Database
DATABASE_URL=postgresql://unisign:unisign@localhost:5432/unisign

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh
JWT_REFRESH_EXPIRES_IN=7d

# Storage (S3 or R2)
STORAGE_PROVIDER=s3
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=unisign-documents

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=UniSign <noreply@unisign.io>

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Gotenberg
GOTENBERG_URL=http://localhost:3030

# App URLs
WEB_URL=http://localhost:3000
APP_URL=http://localhost:3001
SIGN_URL=http://localhost:3002
ADMIN_URL=http://localhost:3003
