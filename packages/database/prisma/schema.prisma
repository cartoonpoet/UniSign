// UniSign — Prisma Schema
// DB: PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────
// 사용자 & 인증
// ─────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  password      String?
  avatarUrl     String?
  phone         String?
  jobTitle      String?
  locale        String    @default("ko")
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  memberships      OrganizationMember[]
  ownedOrgs        Organization[]       @relation("OrgOwner")
  createdDocuments Document[]           @relation("DocumentCreator")
  signerEntries    DocumentSigner[]
  notifications    Notification[]
  refreshTokens    RefreshToken[]
  oauthAccounts    OauthAccount[]

  @@map("users")
}

model OauthAccount {
  id           String  @id @default(cuid())
  userId       String
  provider     String  // "google" | "kakao" | "naver"
  providerId   String
  accessToken  String?
  refreshToken String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@map("oauth_accounts")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─────────────────────────────────────
// 조직 & 팀
// ─────────────────────────────────────

model Organization {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  logoUrl   String?
  website   String?
  industry  String?
  size      String?
  domain    String?
  ownerId   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  owner        User                 @relation("OrgOwner", fields: [ownerId], references: [id])
  members      OrganizationMember[]
  roles        Role[]
  documents    Document[]
  templates    Template[]
  subscription Subscription?

  @@map("organizations")
}

model Role {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  isDefault      Boolean  @default(false)
  permissions    Json
  createdAt      DateTime @default(now())

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      OrganizationMember[]

  @@unique([organizationId, name])
  @@map("roles")
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  roleId         String?
  status         MemberStatus @default(ACTIVE)
  invitedEmail   String?
  inviteToken    String?      @unique
  joinedAt       DateTime?
  createdAt      DateTime     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         Role?        @relation(fields: [roleId], references: [id])

  @@unique([organizationId, userId])
  @@map("organization_members")
}

enum MemberStatus {
  PENDING
  ACTIVE
  INACTIVE
}

// ─────────────────────────────────────
// 문서 & 서명
// ─────────────────────────────────────

model Document {
  id             String         @id @default(cuid())
  organizationId String?
  creatorId      String
  title          String
  status         DocumentStatus @default(DRAFT)
  signingMode    SigningMode     @default(SEQUENTIAL)
  expiresAt      DateTime?
  message        String?
  fileKey        String
  signedFileKey  String?
  fileSize       Int
  pageCount      Int            @default(0)
  hashSha256     String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  creator      User                 @relation("DocumentCreator", fields: [creatorId], references: [id])
  organization Organization?        @relation(fields: [organizationId], references: [id])
  signers      DocumentSigner[]
  fields       SignatureField[]
  auditLogs    AuditLog[]
  sourceFiles  DocumentSourceFile[]

  @@map("documents")
}

model DocumentSourceFile {
  id         String   @id @default(cuid())
  documentId String
  fileKey    String
  fileName   String
  fileSize   Int
  order      Int
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_source_files")
}

enum DocumentStatus {
  DRAFT
  SENT
  PARTIALLY_SIGNED
  COMPLETED
  CANCELLED
  EXPIRED
  DECLINED
}

enum SigningMode {
  SEQUENTIAL
  PARALLEL
  MIXED
}

model DocumentSigner {
  id               String       @id @default(cuid())
  documentId       String
  userId           String?
  email            String
  name             String
  order            Int
  stepGroup        Int          @default(0)
  role             String?
  status           SignerStatus @default(PENDING)
  token            String       @unique
  tokenExpiresAt   DateTime
  signedAt         DateTime?
  declinedAt       DateTime?
  declineReason    String?
  ipAddress        String?
  userAgent        String?
  delegatedToEmail String?
  delegatedToName  String?
  delegatedAt      DateTime?
  createdAt        DateTime     @default(now())

  document   Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user       User?           @relation(fields: [userId], references: [id])
  signatures Signature[]

  @@map("document_signers")
}

enum SignerStatus {
  PENDING
  VIEWED
  SIGNING
  SIGNED
  DECLINED
  DELEGATED
}

model SignatureField {
  id         String    @id @default(cuid())
  documentId String
  signerId   String?
  type       FieldType
  page       Int
  x          Float
  y          Float
  width      Float
  height     Float
  required   Boolean   @default(true)
  label      String?
  color      String?
  createdAt  DateTime  @default(now())

  document  Document   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  signature Signature?

  @@map("signature_fields")
}

enum FieldType {
  SIGNATURE
  INITIAL
  DATE
  TEXT
  CHECKBOX
  STAMP
}

model Signature {
  id        String   @id @default(cuid())
  fieldId   String   @unique
  signerId  String
  type      String   // "drawn" | "typed" | "image"
  data      String
  signedAt  DateTime @default(now())
  ipAddress String?

  field  SignatureField  @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  signer DocumentSigner @relation(fields: [signerId], references: [id], onDelete: Cascade)

  @@map("signatures")
}

// ─────────────────────────────────────
// 템플릿
// ─────────────────────────────────────

model Template {
  id                String    @id @default(cuid())
  organizationId    String?
  creatorId         String
  name              String
  category          String?
  fileKey           String
  isShared          Boolean   @default(false)
  isPinned          Boolean   @default(false)
  usageCount        Int       @default(0)
  defaultExpireDays Int       @default(7)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  organization Organization?       @relation(fields: [organizationId], references: [id])
  signerSlots  TemplateSignerSlot[]
  fieldSlots   TemplateFieldSlot[]

  @@map("templates")
}

model TemplateSignerSlot {
  id         String @id @default(cuid())
  templateId String
  order      Int
  roleName   String?
  stepGroup  Int    @default(0)

  template Template            @relation(fields: [templateId], references: [id], onDelete: Cascade)
  fields   TemplateFieldSlot[]

  @@map("template_signer_slots")
}

model TemplateFieldSlot {
  id         String    @id @default(cuid())
  templateId String
  slotId     String?
  type       FieldType
  page       Int
  x          Float
  y          Float
  width      Float
  height     Float
  required   Boolean   @default(true)
  label      String?

  template Template             @relation(fields: [templateId], references: [id], onDelete: Cascade)
  slot     TemplateSignerSlot?  @relation(fields: [slotId], references: [id])

  @@map("template_field_slots")
}

// ─────────────────────────────────────
// 감사 추적
// ─────────────────────────────────────

model AuditLog {
  id         String     @id @default(cuid())
  documentId String
  actorEmail String
  actorName  String
  event      AuditEvent
  metadata   Json?
  createdAt  DateTime   @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

enum AuditEvent {
  DOCUMENT_CREATED
  DOCUMENT_SENT
  DOCUMENT_VIEWED
  DOCUMENT_SIGNED
  DOCUMENT_DECLINED
  DOCUMENT_COMPLETED
  DOCUMENT_CANCELLED
  DOCUMENT_EXPIRED
  SIGNER_REPLACED
  SIGNER_DELEGATED
  REMINDER_SENT
}

// ─────────────────────────────────────
// 구독 & 결제
// ─────────────────────────────────────

model Subscription {
  id               String             @id @default(cuid())
  organizationId   String             @unique
  plan             PlanType           @default(STARTER)
  status           SubscriptionStatus @default(TRIALING)
  stripeCustomerId String?
  stripeSubId      String?
  trialEndsAt      DateTime?
  currentPeriodEnd DateTime?
  cancelAt         DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoices     Invoice[]

  @@map("subscriptions")
}

enum PlanType {
  STARTER
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

model Invoice {
  id              String        @id @default(cuid())
  subscriptionId  String
  amount          Int
  currency        String        @default("KRW")
  status          InvoiceStatus
  stripeInvoiceId String?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

enum InvoiceStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// ─────────────────────────────────────
// 알림
// ─────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum NotificationType {
  SIGN_REQUEST
  SIGN_COMPLETED
  ALL_SIGNED
  SIGN_DECLINED
  SIGN_EXPIRING
  SIGN_EXPIRED
  MEMBER_JOINED
  DELEGATE_REQUEST
}
